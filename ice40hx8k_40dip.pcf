# iCE40 HX8K Pin Constraints for i8085_40dip
# Target: HX8K CT256 package
#
# This maps the FPGA to a true 40-DIP compatible pinout for drop-in replacement.
# Pin assignments can be adjusted to match your PCB layout.

# Clock and Reset
set_io clk          J3      # System clock input
set_io reset_n      H16     # RESIN - active low reset

# Multiplexed Address/Data Bus (directly matches 8085 pins 12-19)
set_io ad[0]        B3
set_io ad[1]        B4
set_io ad[2]        A1
set_io ad[3]        A2
set_io ad[4]        B5
set_io ad[5]        B6
set_io ad[6]        A5
set_io ad[7]        A6

# High Address Bus (matches 8085 pins 21-28)
set_io a_hi[0]      B7
set_io a_hi[1]      B8
set_io a_hi[2]      A7
set_io a_hi[3]      A8
set_io a_hi[4]      B9
set_io a_hi[5]      B10
set_io a_hi[6]      A9
set_io a_hi[7]      A10

# Bus Control
set_io ale          C8      # ALE - Address Latch Enable
set_io rd_n         C9      # RD - active low read
set_io wr_n         C10     # WR - active low write
set_io io_m_n       D8      # IO/M - high=IO, low=Memory

# Status
set_io s0           D9      # S0 status
set_io s1           D10     # S1 status
set_io resout       E8      # RESOUT - active high during reset

# Interrupts
set_io trap         E9      # TRAP - NMI
set_io rst75        E10     # RST7.5 - edge triggered
set_io rst65        F7      # RST6.5 - level triggered
set_io rst55        F8      # RST5.5 - level triggered
set_io intr         F9      # INTR - general interrupt request
set_io inta_n       G8      # INTA - interrupt acknowledge, active low

# Serial I/O
set_io sid          G9      # SID - Serial Input Data
set_io sod          G10     # SOD - Serial Output Data

# DMA
set_io hold         H9      # HOLD - DMA request
set_io hlda         H10     # HLDA - Hold Acknowledge

# Wait State
set_io ready        J9      # READY - memory/IO ready
