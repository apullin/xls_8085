#!/bin/bash
# XLS Tools Wrapper
# Runs XLS tools via Docker (required for macOS, works anywhere)
#
# Usage: ./xls <tool> [args...]
#
# Examples:
#   ./xls interpreter_main i8085_core.x          # Run DSLX tests
#   ./xls ir_converter_main i8085_core.x --top=execute > i8085_core.ir
#   ./xls opt_main i8085_core.ir > i8085_core.opt.ir
#   ./xls codegen_main i8085_core.opt.ir --generator=combinational
#
# First time setup:
#   cd tools && docker build -t xls -f Dockerfile.xls .

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORK_DIR="$(pwd)"

# Check if xls image exists
if ! docker image inspect xls:latest >/dev/null 2>&1; then
    echo "Error: Docker image 'xls:latest' not found." >&2
    echo "Build it first:" >&2
    echo "  cd $SCRIPT_DIR && docker build -t xls -f Dockerfile.xls ." >&2
    exit 1
fi

# Run the tool with current directory mounted
docker run --rm -i \
    -v "$WORK_DIR:/work" \
    -w /work \
    xls:latest \
    "$@"
