# iCE40 UP5K Pin Constraints for i8085_dip40_plus
# Target: UP5K SG48 package
#
# Same 8085 interface as i8085_dip40 EXCEPT:
#   - a_hi[7:3] (A15-A11) omitted - fixed for external window at 0x7C00
#   - 4 SPI pins added for on-board flash ROM
#
# Pin count: 35 used of 39 available (4 spare)

# Clock and Reset
set_io clk          20      # System clock (12MHz typical)
set_io reset_n      10      # Active-low reset

# Multiplexed Address/Data Bus
set_io ad[0]        46
set_io ad[1]        47
set_io ad[2]        48
set_io ad[3]        2
set_io ad[4]        3
set_io ad[5]        4
set_io ad[6]        6
set_io ad[7]        9

# High Address (A10-A8 only - A15-A11 are fixed for window)
set_io a_hi[0]      28      # A8
set_io a_hi[1]      31      # A9
set_io a_hi[2]      32      # A10

# Bus Control
set_io ale          11
set_io rd_n         12
set_io wr_n         13
set_io io_m_n       18

# Status
set_io s0           19
set_io s1           21
set_io resout       23

# Interrupts
set_io trap         25
set_io rst75        26
set_io rst65        27
set_io rst55        34
set_io intr         35
set_io inta_n       36

# Serial I/O
set_io sid          37
set_io sod          38

# DMA
set_io hold         42
set_io hlda         43

# Wait State
set_io ready        44

# SPI Flash Interface (directly exposed for on-board flash)
set_io spi_sck      15
set_io spi_cs_n     16
set_io spi_mosi     14
set_io spi_miso     17
