# XLS Tools Docker Image
# Provides Google XLS DSLX toolchain for hardware synthesis
#
# Build:  docker build -t xls -f Dockerfile.xls .
# Usage:  ./xls interpreter_main --version

FROM --platform=linux/amd64 debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/xls

# Download and install latest XLS release
RUN LATEST_XLS_RELEASE_TARBALL_URL=$(curl -s -L \
      -H "Accept: application/vnd.github+json" \
      -H "X-GitHub-Api-Version: 2022-11-28" \
      https://api.github.com/repos/google/xls/releases | \
      grep -m 1 -o 'https://.*/releases/download/.*\.tar\.gz') && \
    curl -O -L ${LATEST_XLS_RELEASE_TARBALL_URL} && \
    tar -xzf xls-*.tar.gz --strip-components=1 && \
    rm xls-*.tar.gz

ENV PATH="/opt/xls:${PATH}"

CMD ["/bin/bash"]
